# Postgres
DATABASE_URL=postgresql+asyncpg://glitch:glitch@localhost:5432/glitchhunter

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase (path to service-account JSON downloaded from Firebase console)
FIREBASE_CREDENTIALS=./firebase-service-account.json

# Scraping
SCRAPER_API_KEY=
USE_PROXY=false
SCRAPE_INTERVAL_SECONDS=900

# Glitch thresholds (percent drop vs reference price)
GLITCH_ERROR_THRESHOLD=60
GLITCH_SUPER_THRESHOLD=30
